# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com
# Go to Settings > API to find your project URL and API keys

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: For social login configuration
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
# EXPO_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
# EXPO_PUBLIC_TWITTER_CLIENT_ID=your-twitter-client-id