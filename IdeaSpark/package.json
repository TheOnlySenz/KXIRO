{
  "name": "ideaspark",
  "version": "1.0.0",
  "description": "A platform where users can share startup/viral ideas anonymously or under an alias, and connect instantly with other users",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo build:web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "expo",
    "supabase",
    "startup",
    "ideas",
    "social",
    "networking",
    "cross-platform"
  ],
  "author": "IdeaSpark Team",
  "license": "MIT",
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@supabase/supabase-js": "^2.39.0",
    "expo": "~50.0.0",
    "expo-asset": "~9.0.0",
    "expo-auth-session": "~5.4.0",
    "expo-constants": "~15.4.0",
    "expo-crypto": "~13.0.0",
    "expo-font": "~11.10.0",
    "expo-haptics": "~12.8.0",
    "expo-image-picker": "~14.7.0",
    "expo-linear-gradient": "~12.7.0",
    "expo-linking": "~6.2.0",
    "expo-router": "~3.4.0",
    "expo-status-bar": "~1.11.0",
    "expo-web-browser": "~12.8.0",
    "react": "19.0.0",
    "react-dom": "19.1.1",
    "react-native": "0.73.0",
    "react-native-confetti-cannon": "^1.5.0",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-paper": "^5.12.0",
    "react-native-reanimated": "~3.6.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-share": "^10.0.2",
    "react-native-svg": "14.1.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.19.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/webpack-config": "^20.0.0",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "eslint": "^8.56.0",
    "eslint-config-expo": "^7.0.0",
    "jest": "^29.7.0",
    "typescript": "^5.3.0"
  },
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  }
}
